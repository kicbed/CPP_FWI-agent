# FWI Agent 本地运行配置样例
#
# 使用方法：
#   cp .env.example .env
#   chmod 600 .env
#   编辑 .env 后执行 ./start.sh
#
# .env 已被 Git 忽略。不要在这里保留不再使用的长期密钥，也不要把密钥写进
# README、启动命令、Dockerfile 或 compose.yaml。

# ==================== LLM ====================
# deepseek | qwen | openai | local
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=replace-with-your-deepseek-key

# 若改用其他 provider，只启用对应的一项：
# QWEN_API_KEY=replace-with-your-qwen-key
# OPENAI_API_KEY=replace-with-your-openai-key
# LOCAL_LLM_URL=http://127.0.0.1:11434

# ==================== Agent / MCP ====================
ENABLE_MCP=true
ENABLE_GRPC=false
ENABLE_RAG=false
ROUTING_MODE=agent-rag
TOOL_CALLING_MODE=llm
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# 可选的本地 Embedding；一键启动不会自动下载大型模型。
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_URL=http://127.0.0.1:6000
LOCAL_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B

# ==================== FWI Worker ====================
# 数值解释器固定为 /root/.venvs/cpp-fwi-agent/bin/python，且必须位于仓库外。
# 不接受通过 dotenv/MCP 改成其他 Python 或项目根目录。
FWI_RUN_ROOT=/root/fwi-runs

# ==================== Web ====================
WEB_HOST=127.0.0.1
WEB_PORT=8080
AGENT_BIND_HOST=127.0.0.1
AGENT_CORS_ORIGIN=http://127.0.0.1:8080

# 默认不发送跨域响应头。只有受信任的独立前端确实需要时才配置准确 origin。
# WEB_ALLOW_ORIGIN=http://127.0.0.1:8080
