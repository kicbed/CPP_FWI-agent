# FWI Agent 本地运行配置样例
#
# 使用方法：
#   cp .env.example .env
#   chmod 600 .env
#   编辑 .env 后执行 ./start.sh
#
# 启动器会用 Bash source 加载该文件，其中的 shell 代码会执行。只能加载你自己
# 创建且权限为 600 的可信赋值文件，不要直接使用网上下载的 dotenv。
# .env 已被 Git 忽略。不要在这里保留不再使用的长期密钥，也不要把密钥写进
# README、启动命令、Dockerfile 或 compose.yaml。

# ==================== LLM ====================
# deepseek | qwen | openai | local
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=replace-with-your-deepseek-key

# 若改用其他 provider，只启用对应的一项：
# QWEN_API_KEY=replace-with-your-qwen-key
# OPENAI_API_KEY=replace-with-your-openai-key
# LLM_MODEL=qwen2.5:7b
# LLM_API_URL=http://127.0.0.1:11434/v1/chat/completions

# ==================== Agent / MCP ====================
ENABLE_MCP=true
# 日常使用 ./start.sh --grpc 临时开启；这里保留 false 可避免默认增加端口。
ENABLE_GRPC=false
# MCP Tool-RAG，与下面的 Agent-RAG/本地 FWI 文档检索是不同功能。
ENABLE_RAG=false
# fixed 不需要 AgentCard 向量路由；FWI 理论问题仍会检索本地文档。
ROUTING_MODE=fixed
TOOL_CALLING_MODE=llm
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# 内置 Redis 默认用仓库外目录持久化对话，正常停止/重启后仍可恢复上下文。
# AOF 使用 appendfsync=everysec；异常断电/崩溃时最后约 1 秒可能丢失，且它不是备份或 HA。
# 对话是明文状态；敏感实验可设为 false，或使用受控的加密磁盘目录。
# 若 REDIS_HOST/PORT 已有外部实例，此开关不会更改外部 Redis 的 AOF/RDB；
# 当前不支持 Redis 密码或 TLS，只应连接同机受控实例。
REDIS_PERSISTENCE=true
# 自定义目录必须是专用的绝对目录；已有非空通用目录会被拒绝。
# REDIS_DATA_DIR=/root/.local/state/cpp-fwi-agent/redis

# LLM 上下文窗口采用服务端硬上限：最近完整 user/assistant 回合 + JSON 转义后
# UTF-8 字节预算，不允许客户端放大。
CONTEXT_MAX_MESSAGES=10
CONTEXT_MAX_CHARS=12000
CONTEXT_MAX_MESSAGE_CHARS=4000
CONVERSATION_MAX_STORED_MESSAGES=200
# session 每个完整回合刷新 30 天 TTL；FWI tool state 只在记录新 job_id 时刷新。
CONVERSATION_TTL_SECONDS=2592000

# 可选的本地 Embedding，仅用于 Agent-RAG 的 AgentCard 语义路由。auto 会在
# ROUTING_MODE=agent-rag 且 provider=local 时纳入 ./start.sh / ./stop.sh 管理。
# 一键启动只使用已缓存模型，不会自动联网下载；首次准备请显式运行：
#   deploy/scripts/setup_embedding.sh
ENABLE_LOCAL_EMBEDDING=auto
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_URL=http://127.0.0.1:6000
LOCAL_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
# CPU 避免与 Deepwave FWI 争用 GPU；明确接受显存占用时才能改为 cuda。
LOCAL_EMBEDDING_DEVICE=cpu

# ==================== FWI Worker ====================
# 数值解释器固定为 /root/.venvs/cpp-fwi-agent/bin/python，且必须位于仓库外。
# 不接受通过 dotenv/MCP 改成其他 Python 或项目根目录。
FWI_RUN_ROOT=/root/fwi-runs

# ==================== Web ====================
WEB_HOST=127.0.0.1
WEB_PORT=8080
AGENT_BIND_HOST=127.0.0.1
AGENT_CORS_ORIGIN=http://127.0.0.1:8080

# 默认不发送跨域响应头。只有受信任的独立前端确实需要时才配置准确 origin。
# WEB_ALLOW_ORIGIN=http://127.0.0.1:8080
