# ============================================
# FWI Agent 平台配置文件
# ============================================
# 使用方法：
#   1. 复制这个文件: cp .env.example .env
#   2. 编辑 .env，填入你的 API Key
#   3. 启动: source .env && ./examples/ai_orchestrator/start_system.sh
# ============================================

# ==================== LLM 模型配置 ====================
# 选择一个 LLM 提供商（取消注释你要用的那个）

# --- DeepSeek（推荐，便宜好用）---
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-你的deepseek密钥

# --- 通义千问（阿里）---
# LLM_PROVIDER=qwen
# QWEN_API_KEY=sk-你的qwen密钥

# --- OpenAI ---
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-你的openai密钥

# --- 本地模型（Ollama，完全免费）---
# LLM_PROVIDER=local
# LOCAL_LLM_URL=http://localhost:11434

# ==================== Embedding 模型配置 ====================
# 选择一个 Embedding 方式（取消注释你要用的那个）

# --- 本地 Embedding（推荐，免费）---
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_URL=http://localhost:6000
LOCAL_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B

# --- DashScope API（阿里云）---
# EMBEDDING_PROVIDER=dashscope
# DASHSCOPE_API_KEY=sk-你的dashscope密钥

# ==================== 功能开关 ====================
ENABLE_MCP=true
ROUTING_MODE=agent-rag
TOOL_CALLING_MODE=llm

# ==================== Redis ====================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
