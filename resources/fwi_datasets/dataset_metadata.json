      "acquisition": {
        "type": "2D land",
        "n_sources": 100,
        "n_receivers": 100,
        "source_depth": 0,
        "receiver_depth": 0,
        "source_spacing": 80.0,
        "receiver_spacing": 80.0,
        "frequency_range": [2, 30]
      },
      "sampling": {
        "dt": 0.004,
        "nt": 1500,
        "total_time": 6.0
      },
      "units": {"distance": "meters", "time": "seconds"},
      "file_format": "binary",
      "tags": ["2D", "synthetic", "land", "benchmark"]
    }
  ]
