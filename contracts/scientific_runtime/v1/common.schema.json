{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agent-rpc.local/schemas/scientific-runtime/v1/common.schema.json",
  "title": "Scientific Runtime v1 shared definitions",
  "definitions": {
    "schema_version": {
      "const": "1.0.0"
    },
    "schema_version_1_1": {
      "const": "1.1.0"
    },
    "schema_version_1_2": {
      "const": "1.2.0"
    },
    "identifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
      "maxLength": 128
    },
    "opaque_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
    },
    "semantic_version": {
      "type": "string",
      "pattern": "^(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "extensions": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)+$"
      },
      "additionalProperties": {
        "type": "object"
      },
      "default": {}
    },
    "data_type": {
      "enum": [
        "velocity_model_2d",
        "shot_gather_2d",
        "source_wavelet",
        "inverted_velocity_model_2d",
        "loss_curve",
        "metrics",
        "figure",
        "text"
      ]
    },
    "data_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["port", "data_type"],
      "properties": {
        "port": {"$ref": "#/definitions/identifier"},
        "data_type": {"$ref": "#/definitions/data_type"},
        "shape": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "items": {"type": ["integer", "string"], "minimum": 1}
        },
        "dtype": {
          "enum": ["float32", "float64", "int32", "int64", "uint8", "uint16"]
        },
        "units": {"type": "string", "minLength": 1, "maxLength": 64}
      }
    },
    "dataset_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "content_hash", "data_type"],
      "properties": {
        "id": {"$ref": "#/definitions/identifier"},
        "version": {"$ref": "#/definitions/semantic_version"},
        "content_hash": {"$ref": "#/definitions/sha256"},
        "data_type": {"$ref": "#/definitions/data_type"}
      }
    },
    "algorithm_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": {"$ref": "#/definitions/identifier"},
        "version": {"$ref": "#/definitions/semantic_version"}
      }
    },
    "resource_request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["device", "gpu_count", "cpu_cores", "memory_mb", "wall_time_seconds"],
      "properties": {
        "device": {"enum": ["cpu", "cuda"]},
        "gpu_count": {"type": "integer", "minimum": 0, "maximum": 1},
        "cpu_cores": {"type": "integer", "minimum": 1, "maximum": 64},
        "memory_mb": {"type": "integer", "minimum": 256, "maximum": 262144},
        "wall_time_seconds": {"type": "integer", "minimum": 1, "maximum": 86400}
      },
      "allOf": [
        {
          "if": {"properties": {"device": {"const": "cpu"}}},
          "then": {"properties": {"gpu_count": {"const": 0}}}
        },
        {
          "if": {"properties": {"device": {"const": "cuda"}}},
          "then": {"properties": {"gpu_count": {"const": 1}}}
        }
      ]
    },
    "fwi_parameters_v1_0": {
      "type": "object",
      "additionalProperties": false,
      "required": ["preset", "device", "iterations", "seed"],
      "properties": {
        "preset": {"enum": ["forward", "fwi_smoke", "fwi_demo"]},
        "device": {"enum": ["cpu", "cuda"]},
        "iterations": {"type": "integer", "minimum": 0, "maximum": 10000},
        "seed": {"type": "integer", "minimum": 0, "maximum": 2147483647}
      },
      "allOf": [
        {
          "if": {"properties": {"preset": {"const": "forward"}}},
          "then": {"properties": {"iterations": {"const": 0}}}
        },
        {
          "if": {"properties": {"preset": {"enum": ["fwi_smoke", "fwi_demo"]}}},
          "then": {"properties": {"iterations": {"minimum": 1, "maximum": 10000}}}
        }
      ]
    },
    "fwi_parameters_v1_1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preset",
        "device",
        "iterations",
        "seed",
        "optimizer",
        "learning_rate_milli"
      ],
      "properties": {
        "preset": {"enum": ["fwi_smoke", "fwi_demo"]},
        "device": {"enum": ["cpu", "cuda"]},
        "iterations": {"type": "integer", "minimum": 1, "maximum": 10000},
        "seed": {"type": "integer", "minimum": 0, "maximum": 2147483647},
        "optimizer": {"enum": ["adam", "sgd"]},
        "learning_rate_milli": {
          "type": "integer",
          "minimum": 100,
          "maximum": 1000000000000
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {"optimizer": {"const": "adam"}},
            "required": ["optimizer"]
          },
          "then": {
            "properties": {
              "learning_rate_milli": {"minimum": 100, "maximum": 100000}
            }
          }
        },
        {
          "if": {
            "properties": {"optimizer": {"const": "sgd"}},
            "required": ["optimizer"]
          },
          "then": {
            "properties": {
              "learning_rate_milli": {
                "minimum": 100000000,
                "maximum": 1000000000000
              }
            }
          }
        }
      ]
    },
    "fwi_parameters": {
      "oneOf": [
        {"$ref": "#/definitions/fwi_parameters_v1_0"},
        {"$ref": "#/definitions/fwi_parameters_v1_1"}
      ]
    },
    "dataset_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["port", "dataset"],
      "properties": {
        "port": {"$ref": "#/definitions/identifier"},
        "dataset": {"$ref": "#/definitions/dataset_identity"}
      }
    },
    "node_output_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node_id", "port", "data_type"],
      "properties": {
        "node_id": {"$ref": "#/definitions/identifier"},
        "port": {"$ref": "#/definitions/identifier"},
        "data_type": {"$ref": "#/definitions/data_type"}
      }
    },
    "node_output_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["port", "source"],
      "properties": {
        "port": {"$ref": "#/definitions/identifier"},
        "source": {"$ref": "#/definitions/node_output_identity"}
      }
    },
    "reproducibility_fingerprint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provenance_mode",
        "algorithm",
        "adapter_version",
        "source",
        "environment",
        "runtime",
        "seed",
        "hardware",
        "normalized_config_hash",
        "input_hashes",
        "determinism"
      ],
      "properties": {
        "provenance_mode": {"enum": ["reproducible", "development"]},
        "algorithm": {"$ref": "#/definitions/algorithm_identity"},
        "adapter_version": {"$ref": "#/definitions/semantic_version"},
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": ["identity_complete", "dirty"],
          "properties": {
            "identity_complete": {"type": "boolean"},
            "git_commit": {"type": "string", "pattern": "^[0-9a-f]{40}(?:[0-9a-f]{24})?$"},
            "git_tree": {"type": "string", "pattern": "^[0-9a-f]{40}(?:[0-9a-f]{24})?$"},
            "dirty": {"type": ["boolean", "null"]},
            "diff_hash": {"$ref": "#/definitions/sha256"},
            "source_archive_hash": {"$ref": "#/definitions/sha256"}
          }
        },
        "environment": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "container_image_digest": {"$ref": "#/definitions/sha256"},
            "environment_lock_hash": {"$ref": "#/definitions/sha256"}
          },
          "anyOf": [
            {"required": ["container_image_digest"]},
            {"required": ["environment_lock_hash"]}
          ]
        },
        "runtime": {
          "type": "object",
          "additionalProperties": false,
          "required": ["python", "pytorch", "deepwave", "cuda"],
          "properties": {
            "python": {"type": "string", "minLength": 1},
            "pytorch": {"type": "string", "minLength": 1},
            "deepwave": {"type": "string", "minLength": 1},
            "cuda": {"type": ["string", "null"]}
          }
        },
        "seed": {"type": "integer", "minimum": 0, "maximum": 2147483647},
        "hardware": {
          "type": "object",
          "additionalProperties": false,
          "required": ["device", "device_name"],
          "properties": {
            "device": {"enum": ["cpu", "cuda"]},
            "device_name": {"type": "string", "minLength": 1},
            "compute_capability": {"type": ["string", "null"]}
          }
        },
        "normalized_config_hash": {"$ref": "#/definitions/sha256"},
        "input_hashes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/definitions/sha256"}
        },
        "determinism": {
          "type": "object",
          "additionalProperties": false,
          "required": ["requested", "framework_deterministic", "flags", "known_nondeterminism"],
          "properties": {
            "requested": {"type": "boolean"},
            "framework_deterministic": {"type": "boolean"},
            "flags": {
              "type": "object",
              "additionalProperties": {"type": "boolean"}
            },
            "known_nondeterminism": {
              "type": "array",
              "items": {"type": "string", "minLength": 1, "maxLength": 256}
            }
          }
        }
      },
      "allOf": [
        {
          "if": {"properties": {"provenance_mode": {"const": "reproducible"}}},
          "then": {
            "properties": {
              "source": {
                "required": ["git_commit", "git_tree"],
                "properties": {
                  "identity_complete": {"const": true},
                  "dirty": {"type": "boolean"}
                },
                "allOf": [
                  {
                    "if": {"properties": {"dirty": {"const": true}}},
                    "then": {
                      "anyOf": [
                        {"required": ["diff_hash"]},
                        {"required": ["source_archive_hash"]}
                      ]
                    }
                  }
                ]
              }
            }
          }
        }
      ]
    },
    "artifact_location": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "relative_path": {
          "type": "string",
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$"
        },
        "url": {
          "type": "string",
          "pattern": "^(?:https://[^/]+)?/(?:fwi-artifacts|task-artifacts)/[A-Za-z0-9._/-]+$"
        }
      },
      "oneOf": [
        {
          "required": ["relative_path"]
        },
        {
          "required": ["url"]
        }
      ]
    }
  }
}
