{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agent-rpc.local/schemas/scientific-runtime/v1/run-event.schema.json",
  "title": "RunEvent v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "sequence",
    "task_id",
    "event_type",
    "task_status",
    "occurred_at",
    "fingerprint",
    "extensions"
  ],
  "properties": {
    "schema_version": {"$ref": "common.schema.json#/definitions/schema_version"},
    "event_id": {"$ref": "common.schema.json#/definitions/opaque_id"},
    "sequence": {"type": "integer", "minimum": 1},
    "task_id": {"$ref": "common.schema.json#/definitions/opaque_id"},
    "node_id": {"$ref": "common.schema.json#/definitions/identifier"},
    "event_type": {
      "enum": [
        "task_queued",
        "node_started",
        "node_progress",
        "checkpoint_created",
        "node_waiting",
        "node_retrying",
        "node_succeeded",
        "node_failed",
        "node_cancelled",
        "cancel_requested",
        "task_cancelled"
      ]
    },
    "task_status": {
      "enum": ["Queued", "Running", "Waiting", "Retrying", "Succeeded", "Failed", "Cancelled"]
    },
    "progress": {
      "type": "object",
      "additionalProperties": false,
      "required": ["completed", "total", "unit", "message"],
      "properties": {
        "completed": {"type": "number", "minimum": 0},
        "total": {"type": "number", "minimum": 0},
        "unit": {"enum": ["iterations", "steps", "percent"]},
        "message": {"type": "string", "maxLength": 1000}
      }
    },
    "checkpoint": {"$ref": "common.schema.json#/definitions/artifact_location"},
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message", "retryable"],
      "properties": {
        "code": {"$ref": "common.schema.json#/definitions/identifier"},
        "message": {"type": "string", "minLength": 1, "maxLength": 2000},
        "retryable": {"type": "boolean"}
      }
    },
    "occurred_at": {"$ref": "common.schema.json#/definitions/timestamp"},
    "fingerprint": {"$ref": "common.schema.json#/definitions/reproducibility_fingerprint"},
    "extensions": {"$ref": "common.schema.json#/definitions/extensions"}
  }
}
