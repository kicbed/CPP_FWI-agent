{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agent-rpc.local/schemas/scientific-runtime/v1/algorithm-manifest.schema.json",
  "title": "AlgorithmManifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "version",
    "task_types",
    "parameter_schema",
    "inputs",
    "outputs",
    "resource_limits",
    "security",
    "adapter",
    "extensions"
  ],
  "properties": {
    "schema_version": {"$ref": "common.schema.json#/definitions/schema_version"},
    "id": {"$ref": "common.schema.json#/definitions/identifier"},
    "version": {"$ref": "common.schema.json#/definitions/semantic_version"},
    "task_types": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"enum": ["acoustic_forward_2d", "acoustic_fwi_2d"]}
    },
    "parameter_schema": {
      "type": "object",
      "additionalProperties": false,
      "required": ["$schema", "type", "additionalProperties", "properties", "required"],
      "properties": {
        "$schema": {"const": "http://json-schema.org/draft-07/schema#"},
        "type": {"const": "object"},
        "additionalProperties": {"const": false},
        "properties": {
          "type": "object",
          "additionalProperties": false,
          "required": ["preset", "device", "iterations", "seed"],
          "properties": {
            "preset": {
              "type": "object",
              "additionalProperties": false,
              "required": ["enum"],
              "properties": {"enum": {"const": ["forward", "fwi_smoke", "fwi_demo"]}}
            },
            "device": {
              "type": "object",
              "additionalProperties": false,
              "required": ["enum"],
              "properties": {"enum": {"const": ["cpu", "cuda"]}}
            },
            "iterations": {
              "type": "object",
              "additionalProperties": false,
              "required": ["type", "minimum", "maximum"],
              "properties": {
                "type": {"const": "integer"},
                "minimum": {"const": 0},
                "maximum": {"const": 100}
              }
            },
            "seed": {
              "type": "object",
              "additionalProperties": false,
              "required": ["type", "minimum"],
              "properties": {
                "type": {"const": "integer"},
                "minimum": {"const": 0}
              }
            }
          }
        },
        "required": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": {"enum": ["preset", "device", "iterations", "seed"]},
          "uniqueItems": true
        }
      }
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "common.schema.json#/definitions/data_contract"}
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "common.schema.json#/definitions/data_contract"}
    },
    "resource_limits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["devices", "max_gpu_count", "max_cpu_cores", "max_memory_mb", "max_wall_time_seconds"],
      "properties": {
        "devices": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"enum": ["cpu", "cuda"]}
        },
        "max_gpu_count": {"type": "integer", "minimum": 0, "maximum": 1},
        "max_cpu_cores": {"type": "integer", "minimum": 1, "maximum": 64},
        "max_memory_mb": {"type": "integer", "minimum": 256, "maximum": 262144},
        "max_wall_time_seconds": {"type": "integer", "minimum": 1, "maximum": 86400}
      }
    },
    "security": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowlisted", "side_effects", "arbitrary_paths", "shell", "network_access"],
      "properties": {
        "allowlisted": {"type": "boolean"},
        "side_effects": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"enum": ["compute", "write_artifacts"]}
        },
        "arbitrary_paths": {"const": false},
        "shell": {"const": false},
        "network_access": {"const": false}
      }
    },
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocol", "version", "entrypoint_ref", "methods", "idempotent_submit", "checkpoint_capable"],
      "properties": {
        "protocol": {"const": "algorithm-adapter-v1"},
        "version": {"$ref": "common.schema.json#/definitions/semantic_version"},
        "entrypoint_ref": {"$ref": "common.schema.json#/definitions/identifier"},
        "methods": {
          "type": "array",
          "uniqueItems": true,
          "allOf": [
            {"contains": {"const": "validate"}},
            {"contains": {"const": "estimate"}},
            {"contains": {"const": "submit"}},
            {"contains": {"const": "status"}},
            {"contains": {"const": "cancel"}},
            {"contains": {"const": "collect"}}
          ],
          "items": {"enum": ["validate", "estimate", "submit", "status", "cancel", "collect"]}
        },
        "idempotent_submit": {"const": true},
        "checkpoint_capable": {"type": "boolean"}
      }
    },
    "extensions": {"$ref": "common.schema.json#/definitions/extensions"}
  }
}
