{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agent-rpc.local/schemas/scientific-runtime/v1/plan-graph.schema.json",
  "title": "PlanGraph v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "plan_id",
    "draft",
    "task_type",
    "nodes",
    "missing_fields",
    "plan_hash",
    "created_at",
    "extensions"
  ],
  "properties": {
    "schema_version": {"$ref": "common.schema.json#/definitions/schema_version"},
    "plan_id": {"$ref": "common.schema.json#/definitions/opaque_id"},
    "draft": {
      "type": "object",
      "additionalProperties": false,
      "required": ["draft_id", "revision"],
      "properties": {
        "draft_id": {"$ref": "common.schema.json#/definitions/opaque_id"},
        "revision": {"type": "integer", "minimum": 1}
      }
    },
    "task_type": {"enum": ["acoustic_forward_2d", "acoustic_fwi_2d"]},
    "nodes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "node_id",
          "algorithm",
          "inputs",
          "outputs",
          "dependencies",
          "parameters",
          "resources",
          "side_effects",
          "idempotency_key",
          "risks",
          "acceptance_criteria"
        ],
        "properties": {
          "node_id": {"$ref": "common.schema.json#/definitions/identifier"},
          "algorithm": {"$ref": "common.schema.json#/definitions/algorithm_identity"},
          "inputs": {
            "type": "array",
            "minItems": 1,
            "maxItems": 1,
            "items": {"$ref": "common.schema.json#/definitions/dataset_binding"}
          },
          "outputs": {
            "type": "array",
            "minItems": 1,
            "items": {"$ref": "common.schema.json#/definitions/data_contract"}
          },
          "dependencies": {
            "type": "array",
            "uniqueItems": true,
            "items": {"$ref": "common.schema.json#/definitions/identifier"}
          },
          "parameters": {"$ref": "common.schema.json#/definitions/fwi_parameters"},
          "resources": {"$ref": "common.schema.json#/definitions/resource_request"},
          "side_effects": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {"enum": ["compute", "write_artifacts"]}
          },
          "idempotency_key": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{15,127}$"
          },
          "risks": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["code", "severity", "mitigation"],
              "properties": {
                "code": {"$ref": "common.schema.json#/definitions/identifier"},
                "severity": {"enum": ["low", "medium", "high"]},
                "mitigation": {"type": "string", "minLength": 1, "maxLength": 500}
              }
            }
          },
          "acceptance_criteria": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "description", "required"],
              "properties": {
                "id": {"$ref": "common.schema.json#/definitions/identifier"},
                "description": {"type": "string", "minLength": 1, "maxLength": 500},
                "required": {"type": "boolean"}
              }
            }
          }
        }
      }
    },
    "missing_fields": {
      "type": "array",
      "maxItems": 0
    },
    "plan_hash": {"$ref": "common.schema.json#/definitions/sha256"},
    "created_at": {"$ref": "common.schema.json#/definitions/timestamp"},
    "extensions": {"$ref": "common.schema.json#/definitions/extensions"}
  }
}
