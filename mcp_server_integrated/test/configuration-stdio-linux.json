{
  "mcpServers": {
    "mcp-server": {
      "command": "./build/mcp_server",
      "args": [
        "-l","./build/logs",
        "-p","./build/plugins"
      ],
      "env": {
        "CUSTOM_API_KEY_1": "your-api-key-here",
        "CUSTOM_API_KEY_2": "your-api-key-here",
        "SAVE_DIR": "/path/to/save/directory"
      }
    }
  }
}
